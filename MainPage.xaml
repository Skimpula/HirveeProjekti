<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HirveeProjekti.MainPage"
             Title="Village Newbies Oy - Dashboard">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label Text="Village Newbies Oy" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#2C3E50"
                   HorizontalOptions="Center"/>
            <Label Text="Booking System Dashboard"
                   FontSize="18"
                   TextColor="#7F8C8D"
                   HorizontalOptions="Center"/>

            <!-- Dashboard Buttons -->
            <Grid ColumnSpacing="15" RowSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Manage Areas -->
                <Button Grid.Row="0" Grid.Column="0"
                        Text="Areas"
                        FontSize="16"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="GoToAreas"/>

                <!-- Manage Cottages -->
                <Button Grid.Row="0" Grid.Column="1"
                        Text="Cottages"
                        FontSize="16"
                        BackgroundColor="#2ECC71"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="GoToCottages"/>

                <!-- Manage Customers -->
                <Button Grid.Row="1" Grid.Column="0"
                        Text="Customers"
                        FontSize="16"
                        BackgroundColor="#E67E22"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="GoToCustomers"/>

                <!-- Manage Bookings -->
                <Button Grid.Row="1" Grid.Column="1"
                        Text="Bookings"
                        FontSize="16"
                        BackgroundColor="#9B59B6"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="GoToBookings"/>

                <!-- Manage Services -->
                <Button Grid.Row="2" Grid.Column="0"
                        Text="Services"
                        FontSize="16"
                        BackgroundColor="#1ABC9C"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="GoToServices"/>

                <!-- Manage Invoices -->
                <Button Grid.Row="2" Grid.Column="1"
                        Text="Invoices"
                        FontSize="16"
                        BackgroundColor="#E74C3C"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="GoToInvoices"/>
            </Grid>

            <!-- Footer / Info -->
            <Label Text="© 2026 Village Newbies Oy"
                   FontSize="14"
                   TextColor="#95A5A6"
                   HorizontalOptions="Center"
                   Margin="0,30,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
