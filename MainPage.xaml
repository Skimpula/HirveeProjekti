<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HirveeProjekti.MainPage"
             Title="Village Newbies Oy - Dashboard"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- Otsikkokortti -->
            <Frame BackgroundColor="#1A237E" CornerRadius="12" Padding="20" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Village Newbies Oy"
                           FontSize="26" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="Mökkivarausjärjestelmä"
                           FontSize="15" TextColor="#C5CAE9"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Navigointikortti -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="📂 Hallintapaneeli"
                           FontSize="20" FontAttributes="Bold" TextColor="#1A237E" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0"
                                Text="🗺️ Alueet"
                                FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#3949AB" TextColor="White"
                                CornerRadius="10" HeightRequest="56"
                                Clicked="GoToAreas"/>

                        <Button Grid.Row="0" Grid.Column="1"
                                Text="🏡 Mökit"
                                FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#388E3C" TextColor="White"
                                CornerRadius="10" HeightRequest="56"
                                Clicked="GoToCottages"/>

                        <Button Grid.Row="1" Grid.Column="0"
                                Text="👤 Asiakkaat"
                                FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#F57C00" TextColor="White"
                                CornerRadius="10" HeightRequest="56"
                                Clicked="GoToCustomers"/>

                        <Button Grid.Row="1" Grid.Column="1"
                                Text="📅 Varaukset"
                                FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#7B1FA2" TextColor="White"
                                CornerRadius="10" HeightRequest="56"
                                Clicked="GoToBookings"/>

                        <Button Grid.Row="2" Grid.Column="0"
                                Text="🛎️ Palvelut"
                                FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#00838F" TextColor="White"
                                CornerRadius="10" HeightRequest="56"
                                Clicked="GoToServices"/>

                        <Button Grid.Row="2" Grid.Column="1"
                                Text="🧾 Laskut"
                                FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#C62828" TextColor="White"
                                CornerRadius="10" HeightRequest="56"
                                Clicked="GoToInvoices"/>

                        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                Text="📋 Raportit &amp; Kalenteri"
                                FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#1A237E" TextColor="White"
                                CornerRadius="10" HeightRequest="60"
                                Clicked="GoToReports"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <Label Text="© 2026 Village Newbies Oy"
                   FontSize="13" TextColor="#9E9E9E"
                   HorizontalOptions="Center"
                   Margin="0,4,0,16"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
