<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
             x:Class="HirveeProjekti.Views.CustomersPage"
             Title="Asiakkaat"
             BackgroundColor="#F5F5F5">

    <ContentPage.BindingContext>
        <vm:CustomerViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- Lisää uusi asiakas -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="👤 Lisää uusi asiakas"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Etunimi" FontSize="13" TextColor="Black" />
                            <Entry Placeholder="Etunimi"
                                   Text="{Binding NewCustomerFirstName}"
                                   BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Sukunimi" FontSize="13" TextColor="Black" />
                            <Entry Placeholder="Sukunimi"
                                   Text="{Binding NewCustomerLastName}"
                                   BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Lähiosoite" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Lähiosoite"
                           Text="{Binding NewCustomerAddress}"
                           BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Label Text="Postinumero" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Postinumero"
                           Text="{Binding NewCustomerPostalCode}"
                           BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Label Text="Sähköposti" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Sähköposti"
                           Keyboard="Email"
                           Text="{Binding NewCustomerEmail}"
                           BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Label Text="Puhelinnumero" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Puhelinnumero"
                           Keyboard="Telephone"
                           Text="{Binding NewCustomerPhone}"
                           BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="Black" FontSize="13"
                           IsVisible="{Binding HasError}" />

                    <Button Text="➕ Lisää asiakas"
                            Command="{Binding AddCustomerCommand}"
                            BackgroundColor="#3949AB" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                </VerticalStackLayout>
            </Frame>

            <!-- Asiakkaiden lista -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,24" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="👥 Nykyiset asiakkaat"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <Entry Placeholder="🔍 Etsi asiakasta nimellä..."
                           Text="{Binding SearchText}"
                           BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <CollectionView ItemsSource="{Binding Customers}"
                                    EmptyView="Ei asiakkaita.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#FAFAFA" BorderColor="#C5CAE9"
                                       CornerRadius="8" Padding="12" Margin="0,4">
                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="10">
                                        <BoxView Grid.Column="0" BackgroundColor="#3949AB" CornerRadius="2" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding FullName}"
                                                   FontAttributes="Bold" FontSize="15" TextColor="Black" />
                                            <Label Text="{Binding Lahiosoite, StringFormat='🏠 {0}'}"
                                                   FontSize="13" TextColor="Black" />
                                            <Label Text="{Binding Postinro, StringFormat='📮 {0}'}"
                                                   FontSize="12" TextColor="Black" />
                                            <Label Text="{Binding Email, StringFormat='📧 {0}'}"
                                                   FontSize="12" TextColor="Black" />
                                            <Label Text="{Binding Puhelinnro, StringFormat='📞 {0}'}"
                                                   FontSize="12" TextColor="Black" />
                                            <Button Text="🗑️ Poista"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCustomerCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#E53935" TextColor="White"
                                                    CornerRadius="8" HeightRequest="38" FontSize="13"
                                                    HorizontalOptions="Start" Margin="0,4,0,0"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
