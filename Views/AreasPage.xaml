<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HirveeProjekti.Views.AreasPage"
             Title="Alueet"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🗺️ Alueet"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <Button Text="➕ Lisää uusi alue"
                            BackgroundColor="#3949AB" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold"
                            Clicked="AddArea_Clicked"/>

                    <CollectionView x:Name="AreasCollectionView" SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#FAFAFA" BorderColor="#C5CAE9"
                                       CornerRadius="8" Padding="12" Margin="0,4">
                                    <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="10">
                                        <BoxView Grid.Column="0" BackgroundColor="#3949AB" CornerRadius="2" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Nimi}"
                                               FontSize="15" FontAttributes="Bold" TextColor="Black"
                                               VerticalOptions="Center"/>
                                        <HorizontalStackLayout Grid.Column="2" Spacing="8">
                                            <Button Text="✏️ Muokkaa"
                                                    FontSize="13"
                                                    BackgroundColor="#1976D2" TextColor="White"
                                                    CornerRadius="8" HeightRequest="38"
                                                    Clicked="EditArea_Clicked"/>
                                            <Button Text="🗑️ Poista"
                                                    FontSize="13"
                                                    BackgroundColor="#E53935" TextColor="White"
                                                    CornerRadius="8" HeightRequest="38"
                                                    Clicked="DeleteArea_Clicked"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
