<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HirveeProjekti.Views.AreasPage"
             Title="Alueet">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Header -->
        <Label Text="Alueet"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="#2C3E50"
               HorizontalOptions="Center"/>

        <!-- Add Area Button -->
        <Button Text="Add New Area"
                BackgroundColor="#3498DB"
                TextColor="White"
                CornerRadius="12"
                FontSize="16"
                Clicked="AddArea_Clicked"/>

        <!-- Areas List -->
        <CollectionView x:Name="AreasCollectionView"
                        SelectionMode="Single"
                        Margin="0,10,0,0"
                        HeightRequest="400">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5"
                           CornerRadius="10"
                           HasShadow="True">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="{Binding Nimi}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                            <HorizontalStackLayout HorizontalOptions="EndAndExpand" Spacing="5">
                                <Button Text="Edit"
                                        FontSize="14"
                                        BackgroundColor="#F39C12"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Clicked="EditArea_Clicked"/>
                                <Button Text="Delete"
                                        FontSize="14"
                                        BackgroundColor="#E74C3C"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Clicked="DeleteArea_Clicked"/>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>