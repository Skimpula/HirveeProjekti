<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
          x:Class="HirveeProjekti.Views.CottagesPage"
          Title="Mökit"
          BackgroundColor="#F5F5F5">

    <ContentPage.BindingContext>
        <vm:CottageViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- Lisää uusi mökki -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🏡 Lisää uusi mökki"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <Label Text="Mökin nimi" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Mökin nimi"
                           Text="{Binding NewCottageName}"
                           BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Label Text="Alue" FontSize="13" TextColor="Black" />
                    <Picker Title="Valitse alue"
                            ItemsSource="{Binding Areas}"
                            ItemDisplayBinding="{Binding Nimi}"
                            SelectedItem="{Binding SelectedArea}"
                            BackgroundColor="#EDE7F6"
                            TextColor="Black"
                            TitleColor="#666666" />

                    <Label Text="Osoite" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Osoite"
                           Text="{Binding NewCottageAddress}"
                           BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Hinta (€/yö)" FontSize="13" TextColor="Black" />
                            <Entry Placeholder="Hinta"
                                   Keyboard="Numeric"
                                   Text="{Binding NewCottagePrice}"
                                   BackgroundColor="#EDE7F6"
                                   TextColor="Black"
                                   PlaceholderColor="#666666" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Henkilömäärä" FontSize="13" TextColor="Black" />
                            <Entry Placeholder="Henkilömäärä"
                                   Keyboard="Numeric"
                                   Text="{Binding NewCottageCapacity}"
                                   BackgroundColor="#EDE7F6"
                                   TextColor="Black"
                                   PlaceholderColor="#666666" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Varustelu" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Varustelu"
                           Text="{Binding NewCottageEquipment}"
                           BackgroundColor="#EDE7F6"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="Black" FontSize="13"
                           IsVisible="{Binding HasError}" />

                    <Button Text="➕ Lisää mökki"
                            Command="{Binding AddCottageCommand}"
                            BackgroundColor="#3949AB" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                </VerticalStackLayout>
            </Frame>

            <!-- Hae vapaita mökkejä -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🔍 Hae vapaita mökkejä"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#C8E6C9" Margin="0,0,0,4" />

                    <Label Text="Alue" FontSize="13" TextColor="Black" />
                    <Picker Title="Valitse alue"
                            ItemsSource="{Binding SearchAreas}"
                            ItemDisplayBinding="{Binding Nimi}"
                            SelectedItem="{Binding SelectedSearchArea}"
                            BackgroundColor="#E8F5E9"
                            TextColor="Black"
                            TitleColor="#666666" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Alkaen" FontSize="13" TextColor="Black" />
                            <DatePicker Date="{Binding SearchStartDate}" Format="dd.MM.yyyy" BackgroundColor="#E8F5E9" TextColor="Black" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Päättyen" FontSize="13" TextColor="Black" />
                            <DatePicker Date="{Binding SearchEndDate}" Format="dd.MM.yyyy" BackgroundColor="#E8F5E9" TextColor="Black" />
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="🔍 Hae vapaat mökit"
                            Command="{Binding SearchAvailableCottagesCommand}"
                            BackgroundColor="#388E3C" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                    <Label Text="{Binding SearchMessage}"
                           TextColor="Black" FontSize="13" FontAttributes="Bold"
                           IsVisible="{Binding HasSearchMessage}"
                           HorizontalOptions="Center" />

                    <CollectionView ItemsSource="{Binding AvailableCottages}"
                                    EmptyView="Ei vapaita mökkejä valitulla aikavälillä.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#F1F8E9" BorderColor="#A5D6A7"
                                       CornerRadius="8" Padding="12" Margin="0,4">
                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="10">
                                        <BoxView Grid.Column="0" BackgroundColor="#388E3C" CornerRadius="2" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding Mokkinimi}"
                                                   FontAttributes="Bold" FontSize="15" TextColor="Black" />
                                            <Label Text="{Binding AreaName, StringFormat='📍 {0}'}"
                                                   FontSize="13" TextColor="Black" />
                                            <Label Text="{Binding Katuosoite, StringFormat='🏠 {0}'}"
                                                   FontSize="13" TextColor="Black" />
                                            <HorizontalStackLayout Spacing="12">
                                                <Label Text="{Binding Hinta, StringFormat='💰 {0:F2} €/yö'}"
                                                       FontSize="12" TextColor="Black" />
                                                <Label Text="{Binding Henkilomaara, StringFormat='👥 {0} hlö'}"
                                                       FontSize="12" TextColor="Black" />
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding Varustelu, StringFormat='⚙️ {0}'}"
                                                   FontSize="12" TextColor="Black" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- Nykyiset mökit -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,24" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🏘️ Nykyiset mökit"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <CollectionView ItemsSource="{Binding Cottages}"
                                    EmptyView="Ei mökkejä.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#FAFAFA" BorderColor="#C5CAE9"
                                       CornerRadius="8" Padding="12" Margin="0,4">
                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="10">
                                        <BoxView Grid.Column="0" BackgroundColor="#3949AB" CornerRadius="2" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding Mokkinimi}"
                                                   FontAttributes="Bold" FontSize="15" TextColor="Black" />
                                            <Label Text="{Binding AreaName, StringFormat='📍 {0}'}"
                                                   FontSize="13" TextColor="Black" />
                                            <Label Text="{Binding Katuosoite, StringFormat='🏠 {0}'}"
                                                   FontSize="13" TextColor="Black" />
                                            <HorizontalStackLayout Spacing="12">
                                                <Label Text="{Binding Hinta, StringFormat='💰 {0:F2} €'}"
                                                       FontSize="12" TextColor="Black" />
                                                <Label Text="{Binding Henkilomaara, StringFormat='👥 {0} hlö'}"
                                                       FontSize="12" TextColor="Black" />
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding Varustelu, StringFormat='⚙️ {0}'}"
                                                   FontSize="12" TextColor="Black" />
                                            <Button Text="🗑️ Poista"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCottageCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#E53935" TextColor="White"
                                                    CornerRadius="8" HeightRequest="38" FontSize="13"
                                                    HorizontalOptions="Start" Margin="0,4,0,0"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
