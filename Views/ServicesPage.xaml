<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
             x:Class="HirveeProjekti.Views.ServicesPage"
             Title="Palvelut"
             BackgroundColor="#F5F5F5">

    <ContentPage.BindingContext>
        <vm:ServiceViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- Lisää uusi palvelu -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🛎️ Lisää uusi palvelu"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E1BEE7" Margin="0,0,0,4" />

                    <Label Text="Palvelun nimi" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Palvelun nimi"
                           Text="{Binding NewServiceName}"
                           BackgroundColor="#F3E5F5"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Label Text="Kuvaus" FontSize="13" TextColor="Black" />
                    <Entry Placeholder="Kuvaus"
                           Text="{Binding NewServiceDescription}"
                           BackgroundColor="#F3E5F5"
                           TextColor="Black"
                           PlaceholderColor="#666666" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Hinta (€)" FontSize="13" TextColor="Black" />
                            <Entry Placeholder="Hinta"
                                   Keyboard="Numeric"
                                   Text="{Binding NewServicePrice}"
                                   BackgroundColor="#F3E5F5"
                           TextColor="Black"
                           PlaceholderColor="#666666" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="ALV (%)" FontSize="13" TextColor="Black" />
                            <Entry Placeholder="ALV"
                                   Keyboard="Numeric"
                                   Text="{Binding NewServiceVAT}"
                                   BackgroundColor="#F3E5F5"
                           TextColor="Black"
                           PlaceholderColor="#666666" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="Black" FontSize="13"
                           IsVisible="{Binding HasError}" />

                    <Button Text="➕ Lisää palvelu"
                            Command="{Binding AddServiceCommand}"
                            BackgroundColor="#7B1FA2" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                </VerticalStackLayout>
            </Frame>

            <!-- Palveluiden lista -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,24" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="📋 Nykyiset palvelut"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E1BEE7" Margin="0,0,0,4" />

                    <CollectionView ItemsSource="{Binding Services}"
                                    EmptyView="Ei palveluja.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#FAF5FF" BorderColor="#CE93D8"
                                       CornerRadius="8" Padding="12" Margin="0,4">
                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="10">
                                        <BoxView Grid.Column="0" BackgroundColor="#7B1FA2" CornerRadius="2" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding Nimi}"
                                                   FontAttributes="Bold" FontSize="15" TextColor="Black" />
                                            <Label Text="{Binding Kuvaus, StringFormat='📝 {0}'}"
                                                   FontSize="13" TextColor="Black" />
                                            <HorizontalStackLayout Spacing="12">
                                                <Label Text="{Binding Hinta, StringFormat='💰 {0:F2} €'}"
                                                       FontSize="12" TextColor="Black" />
                                                <Label Text="{Binding Alv, StringFormat='ALV {0:F2}%'}"
                                                       FontSize="12" TextColor="Black" />
                                            </HorizontalStackLayout>
                                            <Button Text="🗑️ Poista"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteServiceCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#E53935" TextColor="White"
                                                    CornerRadius="8" HeightRequest="38" FontSize="13"
                                                    HorizontalOptions="Start" Margin="0,4,0,0"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
