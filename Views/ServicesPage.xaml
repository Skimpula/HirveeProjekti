<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
             x:Class="HirveeProjekti.Views.ServicesPage"
             Title="Palvelut">

    <ContentPage.BindingContext>
        <vm:ServiceViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- 🔹 Otsikko -->
            <Label Text="Palveluiden hallinta"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- ➕ Lisää uusi palvelu -->
            <Label Text="Lisää uusi palvelu" FontAttributes="Bold"/>

            <Entry Placeholder="Palvelun nimi"
                   Text="{Binding NewServiceName}" />
            <Entry Placeholder="Kuvaus"
                   Text="{Binding NewServiceDescription}" />
            <Entry Placeholder="Hinta"
                   Keyboard="Numeric"
                   Text="{Binding NewServicePrice}" />
            <Entry Placeholder="ALV"
                   Keyboard="Numeric"
                   Text="{Binding NewServiceVAT}" />

            <Button Text="Lisää palvelu"
                    Command="{Binding AddServiceCommand}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50" />

            <!-- ⚠️ Virheviesti -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <!-- 📋 Lista palveluista -->
            <Label Text="Nykyiset palvelut"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,20,0,0"/>

            <CollectionView ItemsSource="{Binding Services}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="LightGray"
                               Padding="10"
                               Margin="0,5"
                               CornerRadius="5">
                            <VerticalStackLayout Spacing="5">

                                <Label Text="{Binding Nimi, StringFormat='Palvelu: {0}'}"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding Kuvaus, StringFormat='Kuvaus: {0}'}"/>
                                <Label Text="{Binding Hinta, StringFormat='Hinta: {0:C}'}"/>
                                <Label Text="{Binding Alv, StringFormat='ALV: {0:C}'}"/>

                                <Button Text="Poista"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteServiceCommand}"
                                        CommandParameter="{Binding PalveluId}"
                                        BackgroundColor="#F44336"
                                        TextColor="White"
                                        CornerRadius="8"
                                        HeightRequest="40"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>