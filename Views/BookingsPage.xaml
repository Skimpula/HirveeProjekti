<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
             x:Class="HirveeProjekti.Views.BookingsPage"
             Title="Varaukset">

    <ContentPage.BindingContext>
        <vm:BookingViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- üîπ Otsikko -->
            <Label Text="Uusi varaus"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- üë§ Asiakas -->
            <Label Text="Valitse asiakas" FontAttributes="Bold"/>
            <Picker Title="Asiakas"
                    ItemsSource="{Binding Customers}"
                    ItemDisplayBinding="{Binding FullName}"
                    SelectedItem="{Binding SelectedCustomer}" />

            <!-- üè° M√∂kit -->
            <Label Text="Valitse m√∂kki" FontAttributes="Bold"/>
            <Picker Title="M√∂kki"
                    ItemsSource="{Binding Cottages}"
                    ItemDisplayBinding="{Binding Mokkinimi}"
                    SelectedItem="{Binding SelectedCottage}" />

            <!-- üìÖ P√§iv√§m√§√§r√§t -->
            <Label Text="Alkup√§iv√§" FontAttributes="Bold"/>
            <DatePicker Date="{Binding StartDate}" />

            <Label Text="Loppup√§iv√§" FontAttributes="Bold"/>
            <DatePicker Date="{Binding EndDate}" />

            <!-- ‚öÝÔ∏è Virheviesti -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <!-- ‚ûï Lis√§√§ varaus -->
            <Button Text="{Binding AddButtonText}"
                    Command="{Binding AddBookingCommand}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50" />

            <Button Text="Peruuta muokkaus"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CancelEditCommand}"
                    BackgroundColor="#9E9E9E"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="40"
                    IsVisible="{Binding IsEditMode}" />

            <!-- üìÖ Varauskalenteri -->
            <Label Text="Varauskalenteri (m√∂kki/p√§iv√§)"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,20,0,0"/>

            <ScrollView Orientation="Both" HeightRequest="300">
                <Grid x:Name="CalendarGrid"
                      ColumnSpacing="2" RowSpacing="2"
                      Padding="5">
                    <!-- Calendar will be generated in code-behind or via ViewModel -->
                    <Grid.BindingContext>
                        <Binding Path="CalendarViewModel" />
                    </Grid.BindingContext>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Header row for dates -->
                        <RowDefinition Height="*" /> <!-- Cottage rows (will be generated) -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Cottage name column -->
                        <ColumnDefinition Width="*" /> <!-- Date columns (will be generated) -->
                    </Grid.ColumnDefinitions>
                    <!-- The actual cells will be generated in code-behind or with a custom control -->
                </Grid>
            </ScrollView>

            <!-- üìã Lista varauksista -->
            <Label Text="Nykyiset varaukset"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,20,0,0"/>

            <CollectionView ItemsSource="{Binding Bookings}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="LightGray"
                               Padding="10"
                               Margin="0,5"
                               CornerRadius="5">
                            <VerticalStackLayout Spacing="5">

                                <Label Text="{Binding VarausId, StringFormat='Varaus #{0}'}"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding Asiakas.FullName, StringFormat='Asiakas: {0}'}"/>
                                <Label Text="{Binding Mokki.Mokkinimi, StringFormat='M√∂kki: {0}'}"/>
                                <Label Text="{Binding VarattuAlkuPvm, StringFormat='Alku: {0:dd.MM.yyyy}'}"/>
                                <Label Text="{Binding VarattuLoppuPvm, StringFormat='Loppu: {0:dd.MM.yyyy}'}"/>

                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="Muokkaa"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditBookingCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#2196F3"
                                            TextColor="White"
                                            CornerRadius="8"
                                            HeightRequest="40"/>

                                    <Button Text="Poista"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveBookingCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#F44336"
                                            TextColor="White"
                                            CornerRadius="8"
                                            HeightRequest="40"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>