<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HirveeProjekti.Views.BookingsPage"
             Title="Varaukset"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   Padding="16"
                   Margin="0,0,0,16">

                <VerticalStackLayout Spacing="10">

                    <Label Text="📅 Uusi varaus"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1A237E"/>

                    <BoxView HeightRequest="1"
                             Color="#E8EAF6"/>

                    <Label Text="Asiakas" TextColor="Black"/>
                    <Picker Title="Valitse asiakas"
                            ItemsSource="{Binding Customers}"
                            ItemDisplayBinding="{Binding FullName}"
                            SelectedItem="{Binding SelectedCustomer}"
                            BackgroundColor="#EDE7F6"/>

                    <Label Text="Mökki" TextColor="Black"/>
                    <Picker Title="Valitse mökki"
                            ItemsSource="{Binding Cottages}"
                            ItemDisplayBinding="{Binding Mokkinimi}"
                            SelectedItem="{Binding SelectedCottage}"
                            BackgroundColor="#EDE7F6"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <VerticalStackLayout>
                            <Label Text="Alkupäivä" TextColor="Black"/>
                            <DatePicker Date="{Binding StartDate}"
                                        Format="dd.MM.yyyy"
                                        BackgroundColor="#EDE7F6"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Loppupäivä" TextColor="Black"/>
                            <DatePicker Date="{Binding EndDate}"
                                        Format="dd.MM.yyyy"
                                        BackgroundColor="#EDE7F6"/>
                        </VerticalStackLayout>

                    </Grid>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="Red"
                           IsVisible="{Binding HasError}"/>

                    <Button Text="Tee varaus"
                            Command="{Binding AddBookingCommand}"
                            BackgroundColor="#3949AB"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="46"/>

                </VerticalStackLayout>
            </Frame>

            
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   Padding="16"
                   Margin="0,0,0,16">

                <VerticalStackLayout Spacing="10">

                    <Label Text="📅 Varauskalenteri"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1A237E"/>

                    <BoxView HeightRequest="1"
                             Color="#E8EAF6"/>

                    <ScrollView Orientation="Both"
                                HeightRequest="280"
                                BackgroundColor="#E3F2FD">

                        <Grid x:Name="CalendarGrid"
                              ColumnSpacing="2"
                              RowSpacing="2"
                              BackgroundColor="#90CAF9"
                              Padding="4" />

                    </ScrollView>

                </VerticalStackLayout>
            </Frame>

            
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   Padding="16">

                <VerticalStackLayout Spacing="10">

                    <Label Text="📋 Nykyiset varaukset"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1A237E"/>

                    <BoxView HeightRequest="1"
                             Color="#E8EAF6"/>

                    <CollectionView ItemsSource="{Binding Bookings}"
                                    EmptyView="Ei varauksia.">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Frame BackgroundColor="#FAFAFA"
                                       BorderColor="#C5CAE9"
                                       CornerRadius="8"
                                       Padding="12"
                                       Margin="0,4">

                                    <VerticalStackLayout Spacing="4">

                                        <Label Text="{Binding VarausId, StringFormat='Varaus #{0}'}"
                                               FontAttributes="Bold"
                                               TextColor="Black"/>

                                        <Label Text="{Binding Asiakas.FullName}"
                                               TextColor="Black"/>

                                        <Label Text="{Binding Mokki.Mokkinimi}"
                                               TextColor="Black"/>

                                        <Label Text="{Binding VarattuAlkuPvm, StringFormat='📅 {0:dd.MM.yyyy}'}"
                                               TextColor="Black"/>

                                        <Label Text="{Binding VarattuLoppuPvm, StringFormat='→ {0:dd.MM.yyyy}'}"
                                               TextColor="Black"/>

                                        <HorizontalStackLayout Spacing="8">

                                            <Button Text="✏️"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditBookingCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#1976D2"
                                                    TextColor="White"
                                                    CornerRadius="6"/>

                                            <Button Text="🗑️"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveBookingCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#E53935"
                                                    TextColor="White"
                                                    CornerRadius="6"/>

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                </Frame>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
