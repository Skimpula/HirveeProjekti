<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
             x:Class="HirveeProjekti.Views.InvoicesPage"
             Title="Laskut">

    <ContentPage.BindingContext>
        <vm:InvoiceViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- 🔹 Otsikko -->
            <Label Text="Laskujen hallinta"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- 📋 Lista laskuista -->
            <CollectionView ItemsSource="{Binding Invoices}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="LightGray"
                               Padding="10"
                               Margin="0,5"
                               CornerRadius="5">
                            <VerticalStackLayout Spacing="5">

                                <Label Text="{Binding LaskuId, StringFormat='Lasku ID: {0}'}"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding AsiakasNimi, StringFormat='Asiakas: {0}'}"/>
                                <Label Text="{Binding Summa, StringFormat='Summa: {0:C}'}"/>
                                <Label Text="{Binding Alv, StringFormat='ALV: {0:C}'}"/>
                                <Label Text="{Binding Maksettu, Converter={StaticResource BoolToStatusConverter}, StringFormat='Tila: {0}'}"/>

                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="Merkitse maksetuksi"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkPaidCommand}"
                                            CommandParameter="{Binding LaskuId}"
                                            BackgroundColor="#4CAF50"
                                            TextColor="White"
                                            CornerRadius="8"
                                            HeightRequest="40"/>

                                    <Button Text="Lähetä muistutus"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendReminderCommand}"
                                            CommandParameter="{Binding LaskuId}"
                                            BackgroundColor="#FFC107"
                                            TextColor="Black"
                                            CornerRadius="8"
                                            HeightRequest="40"/>
                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>