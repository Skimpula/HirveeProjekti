<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
             x:Class="HirveeProjekti.Views.InvoicesPage"
             Title="Laskut"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- Luo lasku -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🧾 Luo lasku varauksesta"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <Label Text="Valitse varaus" FontSize="13" TextColor="Black" />
                    <Picker Title="Valitse varaus"
                            ItemsSource="{Binding AvailableBookings}"
                            ItemDisplayBinding="{Binding InvoiceCreationDisplay}"
                            SelectedItem="{Binding SelectedBookingForInvoice}"
                            BackgroundColor="#EDE7F6"
                            TextColor="Black"
                            TitleColor="#666666" />

                    <Button Text="➕ Luo lasku (mökin hinta × päivien määrä)"
                            Command="{Binding CreateInvoiceFromBookingCommand}"
                            BackgroundColor="#3949AB" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                    <Label Text="{Binding InvoiceActionMessage}"
                           TextColor="Black" FontSize="13" FontAttributes="Bold"
                           IsVisible="{Binding HasInvoiceActionMessage}"
                           HorizontalOptions="Center" />

                </VerticalStackLayout>
            </Frame>

            <!-- Laskujen lista -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="📋 Kaikki laskut"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <HorizontalStackLayout Spacing="8" Margin="0,0,0,4">
                        <Button Text="Kaikki"
                                Command="{Binding SetInvoiceFilterCommand}"
                                CommandParameter="All"
                                TextColor="White"
                                CornerRadius="8" HeightRequest="38" FontSize="13">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="All">
                                    <Setter Property="BackgroundColor" Value="#3949AB" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="Paid">
                                    <Setter Property="BackgroundColor" Value="#9E9E9E" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="Unpaid">
                                    <Setter Property="BackgroundColor" Value="#9E9E9E" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="Maksetut"
                                Command="{Binding SetInvoiceFilterCommand}"
                                CommandParameter="Paid"
                                TextColor="White"
                                CornerRadius="8" HeightRequest="38" FontSize="13">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="Paid">
                                    <Setter Property="BackgroundColor" Value="#3949AB" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="All">
                                    <Setter Property="BackgroundColor" Value="#9E9E9E" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="Unpaid">
                                    <Setter Property="BackgroundColor" Value="#9E9E9E" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="Maksamattomat"
                                Command="{Binding SetInvoiceFilterCommand}"
                                CommandParameter="Unpaid"
                                TextColor="White"
                                CornerRadius="8" HeightRequest="38" FontSize="13">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="Unpaid">
                                    <Setter Property="BackgroundColor" Value="#3949AB" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="All">
                                    <Setter Property="BackgroundColor" Value="#9E9E9E" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding InvoiceFilter, Mode=OneWay}" Value="Paid">
                                    <Setter Property="BackgroundColor" Value="#9E9E9E" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding FilteredInvoices}"
                                    EmptyView="Ei laskuja.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#FAFAFA" BorderColor="#C5CAE9"
                                       CornerRadius="8" Padding="12" Margin="0,4">
                                    <Frame.Triggers>
                                        <DataTrigger TargetType="Frame"
                                                     Binding="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectedInvoice.LaskuId}"
                                                     Value="{Binding LaskuId}">
                                            <Setter Property="BackgroundColor" Value="#E8EAF6" />
                                        </DataTrigger>
                                    </Frame.Triggers>
                                    <VerticalStackLayout Spacing="4">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectInvoiceCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </VerticalStackLayout.GestureRecognizers>
                                        <Grid ColumnDefinitions="4,*" ColumnSpacing="10">
                                            <BoxView Grid.Column="0" BackgroundColor="#3949AB" CornerRadius="2" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="3">
                                                <Label Text="{Binding LaskuId, StringFormat='Lasku #{0}'}"
                                                       FontAttributes="Bold" FontSize="15" TextColor="Black" />
                                                <Label Text="{Binding VarausId, StringFormat='Varaus #{0}'}"
                                                       FontSize="13" TextColor="Black" />
                                                <HorizontalStackLayout Spacing="12">
                                                    <Label Text="{Binding Summa, StringFormat='💰 {0:F2} €'}"
                                                           FontAttributes="Bold" FontSize="14" TextColor="Black" />
                                                    <Label Text="{Binding Alv, StringFormat='ALV {0:F2} €'}"
                                                           FontSize="12" TextColor="Black" />
                                                </HorizontalStackLayout>
                                                <Label Text="{Binding TilaTeksti}"
                                                       FontSize="12" TextColor="Black" />
                                            </VerticalStackLayout>
                                        </Grid>
                                        <HorizontalStackLayout Spacing="8" Margin="14,6,0,0">
                                            <Button Text="💳 Vaihda tila"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TogglePaymentStatusCommand}"
                                                    CommandParameter="{Binding LaskuId}"
                                                    BackgroundColor="#388E3C" TextColor="White"
                                                    CornerRadius="8" HeightRequest="38" FontSize="12"/>
                                            <Button Text="📧 Lähetä"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendEmailInvoiceCommand}"
                                                    CommandParameter="{Binding LaskuId}"
                                                    BackgroundColor="#1976D2" TextColor="White"
                                                    CornerRadius="8" HeightRequest="38" FontSize="12"/>
                                            <Button Text="⚠️ Muistutus"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendReminderCommand}"
                                                    CommandParameter="{Binding LaskuId}"
                                                    BackgroundColor="#F57C00" TextColor="White"
                                                    CornerRadius="8" HeightRequest="38" FontSize="12"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- Valitun laskun tiedot -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,24" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="📄 Valitun laskun tiedot"
                           FontSize="20" FontAttributes="Bold" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <Label Text="{Binding SelectedInvoiceDetails}"
                           FontSize="13" TextColor="Black"
                           LineBreakMode="WordWrap" />

                    <Button Text="🖨️ Tulosta PDF"
                            Command="{Binding PrintInvoiceToPdfCommand}"
                            IsEnabled="{Binding IsInvoiceSelected}"
                            BackgroundColor="#3949AB" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
