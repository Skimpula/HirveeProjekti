<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
             x:Class="HirveeProjekti.Views.InvoicesPage"
             Title="Laskut">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- 🔹 Otsikko -->
            <Label Text="Laskujen hallinta"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- 📋 Lista laskuista -->
            <Label Text="Kaikki laskut"
                   FontSize="18"
                   FontAttributes="Bold"/>

            <CollectionView ItemsSource="{Binding Invoices}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="LightGray"
                               BackgroundColor="White"
                               Padding="10"
                               Margin="0,5"
                               CornerRadius="5">
                            <VerticalStackLayout Spacing="5">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectInvoiceCommand}"
                                        CommandParameter="{Binding .}"/>
                                </VerticalStackLayout.GestureRecognizers>

                                <Label Text="{Binding LaskuId, StringFormat='Lasku ID: {0}'}"
                                       FontAttributes="Bold"
                                       TextColor="Black"/>
                                <Label Text="{Binding VarausId, StringFormat='Varaus ID: {0}'}"
                                       TextColor="Black"/>
                                <Label Text="{Binding Summa, StringFormat='Summa: {0:F2} €'}"
                                       TextColor="Black"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding Alv, StringFormat='ALV: {0:F2} €'}"
                                       TextColor="Black"/>
                                <Label Text="{Binding Maksettu, StringFormat='Maksettu: {0}'}"
                                       TextColor="Black"/>

                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="Merkitse maksetuksi"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkPaidCommand}"
                                            CommandParameter="{Binding LaskuId}"
                                            BackgroundColor="#4CAF50"
                                            TextColor="White"
                                            CornerRadius="8"
                                            HeightRequest="40"/>

                                    <Button Text="Lähetä muistutus"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendReminderCommand}"
                                            CommandParameter="{Binding LaskuId}"
                                            BackgroundColor="#FFC107"
                                            TextColor="Black"
                                            CornerRadius="8"
                                            HeightRequest="40"/>
                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- 📄 Valitun laskun tiedot -->
            <BoxView Color="LightGray"
                     HeightRequest="2"
                     Margin="0,10,0,10"/>

            <Label Text="Valitun laskun tiedot"
                   FontSize="18"
                   FontAttributes="Bold"/>

            <Frame BorderColor="LightBlue"
                   Padding="15"
                   Margin="0,5"
                   CornerRadius="8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding SelectedInvoiceDetails}"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>