<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HirveeProjekti.ViewModels"
             x:Class="HirveeProjekti.Views.BookingReportsPage"
             Title="Raportit &amp; Kalenteri"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- ════════════════════════════════════════════════════════
                 OSIO 1 – Majoittumisraportti aikajaksolla + alue
            ════════════════════════════════════════════════════════ -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="📋 Majoittumisraportti aikajaksolla"
                           FontSize="20" FontAttributes="Bold" TextColor="#1A237E" />
                    <BoxView HeightRequest="1" Color="#E8EAF6" Margin="0,0,0,4" />

                    <!-- Aikaväli -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Alkaen" FontSize="13" TextColor="#757575" />
                            <DatePicker Date="{Binding FilterStart}" Format="dd.MM.yyyy" BackgroundColor="#EDE7F6" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Päättyen" FontSize="13" TextColor="#757575" />
                            <DatePicker Date="{Binding FilterEnd}" Format="dd.MM.yyyy" BackgroundColor="#EDE7F6" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Aluesuodatin -->
                    <Label Text="Alue (valinnainen)" FontSize="13" TextColor="#757575" />
                    <Picker ItemsSource="{Binding FilterAreas}"
                            ItemDisplayBinding="{Binding Nimi}"
                            SelectedItem="{Binding SelectedFilterArea}"
                            BackgroundColor="#EDE7F6" />

                    <Button Text="🔍 Hae majoittumiset"
                            Command="{Binding FilterBookingsCommand}"
                            BackgroundColor="#3949AB" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="{Binding BookingCountText}" FontSize="13" TextColor="#546E7A" />
                        <Label Text="|" TextColor="#BDBDBD" />
                        <Label Text="{Binding BookingRevenueTeksti}" FontSize="13" TextColor="#2E7D32" FontAttributes="Bold" />
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding FilteredBookings}"
                                    EmptyView="Ei varauksia valitulla aikavälillä / alueella."
                                    HeightRequest="320">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#FAFAFA" BorderColor="#C5CAE9"
                                       CornerRadius="8" Padding="12" Margin="0,4">
                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="10">
                                        <BoxView Grid.Column="0" BackgroundColor="#3949AB" CornerRadius="2" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding VarausId, StringFormat='Varaus #{0}'}"
                                                   FontAttributes="Bold" FontSize="15" TextColor="#1A237E" />
                                            <Label Text="{Binding Asiakas.FullName, StringFormat='👤 {0}'}"
                                                   FontSize="13" TextColor="#37474F" />
                                            <Label Text="{Binding Mokki.Mokkinimi, StringFormat='🏡 {0}'}"
                                                   FontSize="13" TextColor="#37474F" />
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding VarattuAlkuPvm, StringFormat='📅 {0:dd.MM.yyyy}'}"
                                                       FontSize="12" TextColor="#546E7A" />
                                                <Label Text="→" TextColor="#9E9E9E" FontSize="12" />
                                                <Label Text="{Binding VarattuLoppuPvm, StringFormat='{0:dd.MM.yyyy}'}"
                                                       FontSize="12" TextColor="#546E7A" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- ════════════════════════════════════════════════════════
                 OSIO 2 – Ostettujen palvelujen raportti
            ════════════════════════════════════════════════════════ -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🛎️ Ostettujen palvelujen raportti"
                           FontSize="20" FontAttributes="Bold" TextColor="#4A148C" />
                    <BoxView HeightRequest="1" Color="#E1BEE7" Margin="0,0,0,4" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Alkaen" FontSize="13" TextColor="#757575" />
                            <DatePicker Date="{Binding ServiceReportStart}" Format="dd.MM.yyyy" BackgroundColor="#F3E5F5" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Päättyen" FontSize="13" TextColor="#757575" />
                            <DatePicker Date="{Binding ServiceReportEnd}" Format="dd.MM.yyyy" BackgroundColor="#F3E5F5" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Alue (valinnainen)" FontSize="13" TextColor="#757575" />
                    <Picker ItemsSource="{Binding ServiceReportAreas}"
                            ItemDisplayBinding="{Binding Nimi}"
                            SelectedItem="{Binding SelectedServiceReportArea}"
                            BackgroundColor="#F3E5F5" />

                    <Button Text="📊 Luo palveluraportti"
                            Command="{Binding GenerateServiceReportCommand}"
                            BackgroundColor="#7B1FA2" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                    <Label Text="{Binding ServiceReportSummary}"
                           FontSize="13" TextColor="#4A148C" FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <CollectionView ItemsSource="{Binding ServiceReport}"
                                    EmptyView="Paina 'Luo palveluraportti' nähdäksesi tulokset."
                                    HeightRequest="280">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#FAF5FF" BorderColor="#CE93D8"
                                       CornerRadius="8" Padding="12" Margin="0,4">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding PalveluNimi}"
                                                   FontAttributes="Bold" FontSize="14" TextColor="#4A148C" />
                                            <Label Text="{Binding AlueNimi, StringFormat='📍 {0}'}"
                                                   FontSize="12" TextColor="#757575" />
                                            <Label Text="{Binding AsiakasNimi, StringFormat='👤 {0}'}"
                                                   FontSize="12" TextColor="#546E7A" />
                                            <Label Text="{Binding VarausId, StringFormat='Varaus #{0}'}"
                                                   FontSize="11" TextColor="#9E9E9E" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="End">
                                            <Label Text="{Binding Lkm, StringFormat='× {0}'}"
                                                   FontSize="12" TextColor="#757575" HorizontalOptions="End" />
                                            <Label Text="{Binding YhteensaTeksti}"
                                                   FontAttributes="Bold" FontSize="15" TextColor="#2E7D32" HorizontalOptions="End" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- ════════════════════════════════════════════════════════
                 OSIO 3 – Mökkikalenteri
            ════════════════════════════════════════════════════════ -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🏡 Mökin vapaus/varaus -kalenteri"
                           FontSize="20" FontAttributes="Bold" TextColor="#1B5E20" />
                    <BoxView HeightRequest="1" Color="#C8E6C9" Margin="0,0,0,4" />

                    <Label Text="Valitse mökki" FontSize="13" TextColor="#757575" />
                    <Picker ItemsSource="{Binding Cottages}"
                            ItemDisplayBinding="{Binding Mokkinimi}"
                            SelectedItem="{Binding SelectedCottage}"
                            BackgroundColor="#E8F5E9" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Alkaen" FontSize="13" TextColor="#757575" />
                            <DatePicker Date="{Binding CottageCalendarStart}" Format="dd.MM.yyyy" BackgroundColor="#E8F5E9" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Päättyen" FontSize="13" TextColor="#757575" />
                            <DatePicker Date="{Binding CottageCalendarEnd}" Format="dd.MM.yyyy" BackgroundColor="#E8F5E9" />
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="📅 Päivitä kalenteri"
                            Command="{Binding RefreshCottageCalendarCommand}"
                            BackgroundColor="#388E3C" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                        <HorizontalStackLayout Spacing="6">
                            <BoxView WidthRequest="16" HeightRequest="16" BackgroundColor="#43A047" CornerRadius="3" />
                            <Label Text="Vapaa" FontSize="12" TextColor="#388E3C" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="6">
                            <BoxView WidthRequest="16" HeightRequest="16" BackgroundColor="#E53935" CornerRadius="3" />
                            <Label Text="Varattu" FontSize="12" TextColor="#C62828" />
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding CottageDays}"
                                    EmptyView="Valitse mökki ja paina 'Päivitä kalenteri'."
                                    HeightRequest="340">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="7"
                                             HorizontalItemSpacing="4" VerticalItemSpacing="4" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="{Binding BackgroundColor}" CornerRadius="8"
                                       Padding="2" HasShadow="False" Margin="0">
                                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="{Binding Date, StringFormat='{0:dd}'}"
                                               FontAttributes="Bold" FontSize="15" TextColor="White" HorizontalOptions="Center" />
                                        <Label Text="{Binding Date, StringFormat='{0:ddd}'}"
                                               FontSize="9" TextColor="#EEEEEE" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- ════════════════════════════════════════════════════════
                 OSIO 4 – Palvelukalenteri
            ════════════════════════════════════════════════════════ -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16" Margin="0,0,0,24" HasShadow="True">
                <VerticalStackLayout Spacing="10">

                    <Label Text="🗓️ Palvelun päiväkalenteri"
                           FontSize="20" FontAttributes="Bold" TextColor="#BF360C" />
                    <BoxView HeightRequest="1" Color="#FFCCBC" Margin="0,0,0,4" />

                    <Label Text="Valitse palvelu" FontSize="13" TextColor="#757575" />
                    <Picker ItemsSource="{Binding Services}"
                            ItemDisplayBinding="{Binding Nimi}"
                            SelectedItem="{Binding SelectedService}"
                            BackgroundColor="#FBE9E7" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Alkaen" FontSize="13" TextColor="#757575" />
                            <DatePicker Date="{Binding ServiceCalendarStart}" Format="dd.MM.yyyy" BackgroundColor="#FBE9E7" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Päättyen" FontSize="13" TextColor="#757575" />
                            <DatePicker Date="{Binding ServiceCalendarEnd}" Format="dd.MM.yyyy" BackgroundColor="#FBE9E7" />
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="📅 Päivitä kalenteri"
                            Command="{Binding RefreshServiceCalendarCommand}"
                            BackgroundColor="#E64A19" TextColor="White"
                            CornerRadius="8" HeightRequest="46" FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                        <HorizontalStackLayout Spacing="6">
                            <BoxView WidthRequest="16" HeightRequest="16" BackgroundColor="#43A047" CornerRadius="3" />
                            <Label Text="Vapaa" FontSize="12" TextColor="#388E3C" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="6">
                            <BoxView WidthRequest="16" HeightRequest="16" BackgroundColor="#E53935" CornerRadius="3" />
                            <Label Text="Varattu" FontSize="12" TextColor="#C62828" />
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding ServiceDays}"
                                    EmptyView="Valitse palvelu ja paina 'Päivitä kalenteri'."
                                    HeightRequest="340">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="7"
                                             HorizontalItemSpacing="4" VerticalItemSpacing="4" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="{Binding BackgroundColor}" CornerRadius="8"
                                       Padding="2" HasShadow="False" Margin="0">
                                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="{Binding Date, StringFormat='{0:dd}'}"
                                               FontAttributes="Bold" FontSize="15" TextColor="White" HorizontalOptions="Center" />
                                        <Label Text="{Binding Date, StringFormat='{0:ddd}'}"
                                               FontSize="9" TextColor="#EEEEEE" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
